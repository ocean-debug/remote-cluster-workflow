{
  "profileName": "direct-shell-example",
  "sshTarget": "user@example-host",
  "sshOptions": [
    "-p",
    "22"
  ],
  "remoteShell": "bash",
  "remoteWorkdir": "/data/project",
  "preCommands": [
    "source ~/.bashrc"
  ],
  "environment": {
    "activate": "conda activate analysis-env"
  },
  "resource": {
    "template": "bash -lc {command_quoted}",
    "defaults": {
      "node": "login",
      "cores": "4"
    }
  }
}
