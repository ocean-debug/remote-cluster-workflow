{
  "profileName": "slurm-srun-example",
  "sshTarget": "user@login-host",
  "remoteWorkdir": "/home/user/project",
  "preCommands": [
    "source ~/.bashrc"
  ],
  "environment": {
    "activate": "conda activate ml-env"
  },
  "resource": {
    "template": "srun -w {node} -c {cores} -p {partition} bash -lc {command_quoted}",
    "defaults": {
      "node": "gpu03",
      "cores": "8",
      "partition": "gpu"
    }
  }
}
